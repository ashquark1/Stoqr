{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx tsc -p tsconfig.app.json --noEmit"
          }
        ]
      }
    ]
  },
  "claudeMdExcludes": [
    "**/node_modules/**",
    "**/dist/**",
    "**/.angular/**",
    "**/coverage/**",
    "**/build/**"
  ]
}
